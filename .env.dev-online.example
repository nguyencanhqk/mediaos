# .env.dev-online — OVERRIDE cho DEV-ONLINE (lộ dev stack ra cian-dev.* qua cloudflared, song song prod).
# `m dev-online` nạp .env.dev TRƯỚC (base: JWT/KMS/VALKEY/S3...) rồi file này (đè). `m dev-online` tự copy
# file .example này → .env.dev-online (đã gitignore) nếu chưa có. KHÔNG commit .env.dev-online.

# API dev-online port RIÊNG (prod giữ 3100; dev-online 3200) → chạy song song được.
API_PORT=3200
# Sau cloudflared (1 hop) → đọc X-Forwarded-For cho req.ip đúng (CS-9 IP allowlist).
TRUST_PROXY=1

# DB CÔ LẬP: mediaos_dev (direct :5432, KHÔNG qua PgBouncer vốn chỉ route `mediaos`). RLS vẫn ép (mediaos_app
# không BYPASSRLS). Tạo + migrate + seed bằng `m dev-online-db`. Mật khẩu role = cluster Postgres hiện tại:
#   - mặc định changeme_* (khi prod-API KHÔNG chạy / cluster đang ở dev).
#   - chạy SONG SONG prod-API: đổi 3 mật khẩu dưới sang mật khẩu role PROD (xem .env.prod) cho KHỚP cluster,
#     vì role Postgres là cluster-global (1 mật khẩu/role cho mọi DB).
DATABASE_URL=postgres://mediaos_app:changeme_app_only@localhost:5432/mediaos_dev
DATABASE_DIRECT_URL=postgres://mediaos:changeme_dev_only@localhost:5432/mediaos_dev
DATABASE_WORKER_URL=postgres://mediaos_worker:changeme_worker_only@localhost:5432/mediaos_dev

# SSO cookie qua HTTPS edge (cloudflared kết thúc TLS). Các host cian-dev.* cùng-site funtimemediacorp.com
# → cookie SameSite=Strict vẫn gửi giữa chúng; Domain dưới để FE đọc được CSRF cookie (double-submit).
# ⚠️ Domain .funtimemediacorp.com TRÙNG prod → 1 trình duyệt KHÔNG đăng nhập đồng thời prod + dev được
#    (cookie cùng tên/đè nhau). Test dev bằng trình duyệt/profile KHÁC với prod.
AUTH_COOKIE_DOMAIN=.funtimemediacorp.com
AUTH_COOKIE_SECURE=true
CORS_ORIGIN=https://cian-dev.funtimemediacorp.com,https://cian-dev-auth.funtimemediacorp.com,https://cian-dev-console.funtimemediacorp.com
AUTH_REDIRECT_ALLOWLIST=https://cian-dev.funtimemediacorp.com,https://cian-dev-console.funtimemediacorp.com

# FE trỏ tới host tunnel (nhúng lúc Vite dev qua process.env). VITE_TUNNEL_HOST set RIÊNG mỗi app bởi `m dev-online`.
VITE_API_URL=https://cian-dev-api.funtimemediacorp.com/api/v1
VITE_AUTH_APP_URL=https://cian-dev-auth.funtimemediacorp.com
VITE_DEFAULT_APP_URL=https://cian-dev.funtimemediacorp.com

# 2FA tắt cho dễ login dev.
TWO_FACTOR_ENFORCEMENT_ENABLED=false
