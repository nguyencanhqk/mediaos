{
  "name": "@mediaos/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "build": "nest build",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
