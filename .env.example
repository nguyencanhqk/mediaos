# MediaOS — biến môi trường MẪU. Copy: `cp .env.example .env` rồi điền giá trị thật.
# `.env` đã gitignore. KHÔNG bao giờ commit secret thật (BẤT BIẾN #3).

# ─────────────────────────────────────────────────────────────
# Postgres (docker-compose)
# ─────────────────────────────────────────────────────────────
POSTGRES_USER=mediaos
POSTGRES_PASSWORD=changeme_dev_only
POSTGRES_DB=mediaos
POSTGRES_PORT=5432
PGBOUNCER_PORT=6432

# ─────────────────────────────────────────────────────────────
# Kết nối ứng dụng (G2-1: 3 role tách quyền — KHÔNG dùng superuser cho app)
#   DATABASE_URL        → mediaos_app QUA PgBouncer (:6432). MỌI query nghiệp vụ (RLS ép ở đây).
#   DATABASE_DIRECT_URL → superuser/owner, direct (:5432). Migration + bootstrap role.
#   DATABASE_WORKER_URL → mediaos_worker, direct (:5432). Outbox worker (G2-4).
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgres://mediaos_app:changeme_app_only@localhost:6432/mediaos
DATABASE_DIRECT_URL=postgres://mediaos:changeme_dev_only@localhost:5432/mediaos
DATABASE_WORKER_URL=postgres://mediaos_worker:changeme_worker_only@localhost:5432/mediaos
# PGBOUNCER_URL: dùng riêng cho integration test kiểm chứng tenant isolation qua pooler.
# Bằng DATABASE_URL ở local (cùng trỏ PgBouncer :6432). Vắng → test pgbouncer tự skip.
PGBOUNCER_URL=postgres://mediaos_app:changeme_app_only@localhost:6432/mediaos

# ─────────────────────────────────────────────────────────────
# Mật khẩu DB role — DÙNG BỞI scripts/setup-db-roles.mjs (gán qua ALTER ROLE), TÁCH khỏi migration.
# Phải KHỚP với mật khẩu trong các URL ở trên. Chạy: `pnpm db:migrate && pnpm db:setup-roles`.
# ─────────────────────────────────────────────────────────────
APP_DB_PASSWORD=changeme_app_only
WORKER_DB_PASSWORD=changeme_worker_only
PGBOUNCER_AUTH_PASSWORD=changeme_pgbauth_only
# OWNER_DB_PASSWORD=  # chỉ cần khi prod chạy migration bằng mediaos_owner

# ─────────────────────────────────────────────────────────────
# Valkey (cache / queue / presence)
# ─────────────────────────────────────────────────────────────
VALKEY_PORT=6379
VALKEY_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────
# MinIO / S3 (object storage — artifact nhỏ; video lưu link, xem infra-zero-cost-plan §4)
# ─────────────────────────────────────────────────────────────
MINIO_ROOT_USER=mediaos
MINIO_ROOT_PASSWORD=changeme_dev_only
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=mediaos
S3_SECRET_KEY=changeme_dev_only
S3_BUCKET=mediaos-assets
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
# TTL (giây) presigned URL cho PUT/GET — ephemeral, KHÔNG persist. Max 3600.
S3_PRESIGN_TTL_SEC=300

# ─────────────────────────────────────────────────────────────
# API (NestJS)
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3100
API_PREFIX=api
API_VERSION=v1
# Số hop reverse-proxy tin cậy để đọc X-Forwarded-For đúng. Dev (không proxy) = 'false'.
# Staging/prod sau nginx/LB: đặt số hop (vd '1') hoặc CIDR proxy (vd '10.0.0.0/8').
TRUST_PROXY=false
# Kill-switch Socket.IO gateway. 'false' = tắt realtime (FE vẫn poll REST). Dev thường để 'true'.
REALTIME_ENABLED=true
# CORS allowlist (origin tường minh, phẩy — KHÔNG '*' vì credentials:true). FS-1b SSO dev = subdomain
# *.localhost (web./auth.) để cookie Domain=localhost chạy giống prod. Giữ localhost:5273 cho dev non-SSO cũ.
# FS-2/3/4 (Wave 2): thêm 3 product app studio.(5276)/people.(5277)/console.(5278). PM-1: projects.(5279).
CORS_ORIGIN=http://localhost:5273,http://web.localhost:5273,http://auth.localhost:5275,http://studio.localhost:5276,http://people.localhost:5277,http://console.localhost:5278,http://localhost:5279,http://projects.localhost:5279

# ─────────────────────────────────────────────────────────────
# Auth / JWT (DEVOPS-04 §8.3 — bắt buộc MVP, secret tách môi trường)
# Tạo secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ─────────────────────────────────────────────────────────────
# JWT_SECRET: ký cả access + refresh token. MIN 32 ký tự. KHÔNG commit giá trị thật (BẤT BIẾN #3).
JWT_SECRET=changeme_at_least_32_chars_dev_only_000000000000
# TTL (giây): access 15 phút, refresh 30 ngày, reset-password 1 giờ.
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=2592000
RESET_TOKEN_TTL_SEC=3600
# Phiên operator (platform-admin, aud='operator') — TTL ngắn hơn (cửa sổ rủi ro cao).
OPERATOR_ACCESS_TOKEN_TTL_SEC=600
# Bảo vệ đăng nhập: khoá tạm sau N lần sai — per-IP và per-account (chặn credential-stuffing).
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SEC=900
LOGIN_ACCOUNT_MAX_ATTEMPTS=20
# Ép 2FA server-side cho role requires_two_factor. 'true' = bắt buộc (default prod). Dev: đặt 'false'.
TWO_FACTOR_ENFORCEMENT_ENABLED=false
# Kill-switch enforcement chính sách bảo mật per-company (IP/giờ/email-domain). 'true' = bật.
SECURITY_POLICY_ENFORCEMENT_ENABLED=true
# Kill-switch SaaS feature flag / usage limit enforcement. 'true' = bật.
SAAS_ENFORCEMENT_ENABLED=true
# URL trang kích hoạt tài khoản (mời nhân viên). Rỗng → invite gửi nhưng emailSent:false.
# INVITE_ACTIVATION_URL=http://auth.localhost:5275/activate

# ─────────────────────────────────────────────────────────────
# Background worker scheduler (WAVE 4 OPS) — gọi processBatch() định kỳ
# ─────────────────────────────────────────────────────────────
# OutboxWorker + DbExportWorker là one-shot processBatch(); WorkerSchedulerService đăng ký 2 interval ĐỘC
# LẬP gọi định kỳ. Kill-switch dưới đây + TỰ TẮT khi NODE_ENV=test (spec gọi processBatch trực tiếp).
# Đa-instance an toàn: mọi instance tick nhưng worker claim bằng FOR UPDATE SKIP LOCKED (không double-process).
WORKERS_SCHEDULER_ENABLED=true
# Chu kỳ poll (ms) — số nguyên dương. outbox dày hơn (độ trễ giao event), export thưa hơn.
OUTBOX_POLL_MS=5000
EXPORT_POLL_MS=10000

# ─────────────────────────────────────────────────────────────
# SSO cookie session (FS-1) — refresh + CSRF cookie subdomain + open-redirect allowlist
# ─────────────────────────────────────────────────────────────
# AUTH_COOKIE_DOMAIN: domain cho refresh/CSRF cookie. Dev *.localhost = 'localhost' (cookie gửi cho MỌI
# *.localhost: web./auth./api.). Prod = '.<domain>' (vd '.funtimemediacorp.com'). Rỗng = host-only (KHÔNG share subdomain).
AUTH_COOKIE_DOMAIN=localhost
# AUTH_COOKIE_SECURE: cờ Secure. Dev http *.localhost = 'false'. Prod BẮT BUỘC 'true' (cần TLS wildcard *.<domain>).
AUTH_COOKIE_SECURE=false
# AUTH_REDIRECT_ALLOWLIST: origin (phẩy) được phép cho `?redirect` sau đăng nhập (chống open-redirect, rủi ro #11).
# Rỗng = deny-all (fail-closed). FS-2/3/4 (Wave 2) đã thêm studio./people./console. PM-1 thêm projects.(5279). Prod = origin https thật.
AUTH_REDIRECT_ALLOWLIST=http://web.localhost:5273,http://studio.localhost:5276,http://people.localhost:5277,http://console.localhost:5278,http://projects.localhost:5279

# ─────────────────────────────────────────────────────────────
# KMS / Envelope encryption (G6-2) — platform_accounts secrets, reset-token
# ─────────────────────────────────────────────────────────────
# 'local' = DEV: KEK 32 byte đọc từ file .secrets/ (ADR-0004 cấm KEK-in-env-host cho prod).
# 'vault' = PROD: HashiCorp Vault transit (cần KMS_VAULT_ADDR + KMS_VAULT_TOKEN).
KMS_PROVIDER=local
# Tạo KEK dev: node -e "require('fs').writeFileSync('.secrets/local-kek.bin',require('crypto').randomBytes(32))"
# Đặt đường dẫn TUYỆT ĐỐI (process cwd = apps/api khi chạy). KHÔNG commit file KEK (.secrets/ đã gitignore).
KMS_LOCAL_KEK_PATH=/abs/path/to/MediaOS/.secrets/local-kek.bin
# Chỉ cần khi KMS_PROVIDER=vault:
# KMS_VAULT_ADDR=http://localhost:8200
# KMS_VAULT_TOKEN=changeme_dev_only
# ⚠️ Rotation worker fail-closed: SecretRotationService CHẶN chạy bằng role BYPASS RLS (super/bypassrls) vì
# role đó ghi đè được secret_ciphertext (bỏ qua column-grant). Chỉ đặt ='true' cho harness test seed/teardown
# bằng superuser — TUYỆT ĐỐI KHÔNG ở staging/prod. Mặc định (unset) = chặn. Chỉ chuỗi đúng 'true' mới nới.
# (Để value = false ở đây để bulk-uncomment .env.example vẫn fail-closed; bật bằng tay khi cần.)
ALLOW_SUPERUSER_ROTATION=false

# ─────────────────────────────────────────────────────────────
# AI Insight (AI-1) — Claude API tóm tắt KPI + chi phí (read-only)
# ─────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY: khoá Claude API. KHÔNG commit giá trị thật (BẤT BIẾN #3) — để RỖNG ở .env.example.
# Thiếu key → GET /ai/insight trả 503 (fail-fast cấu hình, KHÔNG fail-open). Điền giá trị thật ở .env.
ANTHROPIC_API_KEY=
# AI_MODEL: model mặc định từ allowlist (KHÔNG hậu tố ngày → 404). Default claude-opus-4-8.
# AI_MODEL=claude-opus-4-8   # hoặc claude-sonnet-4-6 (rẻ/nhanh hơn)

# ─────────────────────────────────────────────────────────────
# Admin seed — tài khoản đăng nhập đầu tiên (KHÔNG còn seed-lúc-khởi-động)
# ─────────────────────────────────────────────────────────────
# Các *BootstrapService cũ (platform-operator / super-admin chéo tenant, thời media) ĐÃ GỠ khi de-media-fy.
# Tài khoản admin nay tạo TƯỜNG MINH qua script idempotent, chạy SAU `pnpm db:migrate`:
#   • DEV:  apps/api/demo-seed-base.mjs → company `demo` + admin@demo.local / Admin@12345  (qua `m reset` / `m seed`)
#   • PROD: apps/api/seed-admin.mjs     → đọc các biến ADMIN_* dưới đây              (qua `m deploy-seed`)
# Role gán: `company-admin` (role 0001, migration 0005) = full quản trị công ty (single-tenant). Script tạo
# company nếu thiếu + UPSERT user + gán role (idempotent, chạy lại reset mật khẩu).
# ⚠️ Mật khẩu ≥12 ký tự, chỉ đặt ở môi trường tin cậy, KHÔNG commit (BẤT BIẾN #3). Script KHÔNG log mật khẩu.
# ADMIN_COMPANY_SLUG=funtime
# ADMIN_COMPANY_NAME=Funtime Media Corp
# ADMIN_EMAIL=admin@funtimemediacorp.com
# ADMIN_PASSWORD=ChangeMe_StrongAdminPassword
# ADMIN_NAME=Administrator

# ─────────────────────────────────────────────────────────────
# Web (Vite) — chỉ biến VITE_* lộ ra client. KHÔNG đặt secret ở đây.
# ─────────────────────────────────────────────────────────────
# FS-1b SSO dev: trỏ API qua `api.localhost` để cookie `Domain=localhost` (refresh/CSRF) tự đính kèm trên
# fetch credentials:'include' (localhost host cũng nhận, nhưng *.localhost mới giống prod). Dev non-SSO cũ:
# đặt lại http://localhost:3100/api/v1 + AUTH_COOKIE_DOMAIN rỗng.
VITE_API_URL=http://api.localhost:3100/api/v1
# VITE_AUTH_APP_URL: app đăng nhập trung tâm (apps/auth). web-core điều hướng tới đây khi phiên hỏng (silent-
# refresh fail / refresh-on-401 fail) kèm `?redirect=<đích>`. Dev = auth.localhost:5275.
VITE_AUTH_APP_URL=http://auth.localhost:5275
# VITE_DEFAULT_APP_URL: landing mặc định của apps/auth sau đăng nhập khi `?redirect` vắng/không hợp lệ. Dev = web.localhost:5273.
VITE_DEFAULT_APP_URL=http://web.localhost:5273
# FS-5 launcher (apps/web): URL TUYỆT ĐỐI tới 3 product app cho các tile launcher (link cross-origin). Dev =
# subdomain *.localhost:<port> khớp vite.config từng app. Build từng app phải nhúng đúng các biến này.
VITE_STUDIO_URL=http://studio.localhost:5276
VITE_PEOPLE_URL=http://people.localhost:5277
VITE_CONSOLE_URL=http://console.localhost:5278
VITE_PROJECTS_URL=http://projects.localhost:5279

# ─────────────────────────────────────────────────────────────
# Backup offsite (G1-8) — điền khi vận hành thật
# ─────────────────────────────────────────────────────────────
BACKUP_DIR=./backups
BACKUP_GPG_RECIPIENT=
BACKUP_B2_REMOTE=b2:mediaos-backup
BACKUP_RETENTION_DAILY=7

# ═════════════════════════════════════════════════════════════
# FS-5 CUTOVER — TEMPLATE PROD (multi-subdomain SSO). Domain placeholder = `funtimemediacorp.com`.
# Thay `funtimemediacorp.com` bằng domain thật + đặt các biến này TRONG MÔI TRƯỜNG PROD (KHÔNG commit).
# Runbook đầy đủ (DNS · TLS wildcard · reverse proxy · CI per-app · checklist): docs/ops/fs5-cutover-runbook.md
# Mỗi VITE_* phải nhúng lúc BUILD app tương ứng (build-time, không runtime). API đọc CORS/COOKIE lúc khởi động.
# ═════════════════════════════════════════════════════════════
# --- API (apps/api @ api.funtimemediacorp.com) ---
# NODE_ENV=production
# AUTH_COOKIE_DOMAIN=.funtimemediacorp.com        # cookie refresh/CSRF share mọi subdomain (đầu '.' bắt buộc)
# AUTH_COOKIE_SECURE=true                     # BẮT BUỘC prod — cần TLS wildcard *.funtimemediacorp.com
# CORS_ORIGIN=https://funtimemediacorp.com,https://studio.funtimemediacorp.com,https://people.funtimemediacorp.com,https://console.funtimemediacorp.com,https://projects.funtimemediacorp.com,https://auth.funtimemediacorp.com
# AUTH_REDIRECT_ALLOWLIST=https://funtimemediacorp.com,https://studio.funtimemediacorp.com,https://people.funtimemediacorp.com,https://console.funtimemediacorp.com,https://projects.funtimemediacorp.com
# KMS_PROVIDER=vault                          # prod KHÔNG dùng KEK-in-file (ADR-0004)
# KMS_VAULT_ADDR=https://vault.funtimemediacorp.com
# KMS_VAULT_TOKEN=<từ secret manager, KHÔNG commit>
# --- apps/web (LAUNCHER @ funtimemediacorp.com, root domain) ---
# VITE_API_URL=https://api.funtimemediacorp.com/api/v1
# VITE_AUTH_APP_URL=https://auth.funtimemediacorp.com
# VITE_STUDIO_URL=https://studio.funtimemediacorp.com
# VITE_PEOPLE_URL=https://people.funtimemediacorp.com
# VITE_CONSOLE_URL=https://console.funtimemediacorp.com
# VITE_PROJECTS_URL=https://projects.funtimemediacorp.com
# --- apps/auth (@ auth.funtimemediacorp.com) ---
# VITE_API_URL=https://api.funtimemediacorp.com/api/v1
# VITE_DEFAULT_APP_URL=https://funtimemediacorp.com   # bounce về launcher khi `?redirect` vắng/không hợp lệ
# --- apps/{studio,people,console} (mỗi app @ subdomain riêng) ---
# VITE_API_URL=https://api.funtimemediacorp.com/api/v1
# VITE_AUTH_APP_URL=https://auth.funtimemediacorp.com
