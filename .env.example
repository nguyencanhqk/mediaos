# MediaOS — biến môi trường MẪU. Copy: `cp .env.example .env` rồi điền giá trị thật.
# `.env` đã gitignore. KHÔNG bao giờ commit secret thật (BẤT BIẾN #3).

# ─────────────────────────────────────────────────────────────
# Postgres (docker-compose)
# ─────────────────────────────────────────────────────────────
POSTGRES_USER=mediaos
POSTGRES_PASSWORD=changeme_dev_only
POSTGRES_DB=mediaos
POSTGRES_PORT=5432
PGBOUNCER_PORT=6432

# ─────────────────────────────────────────────────────────────
# Kết nối ứng dụng (G2-1: 3 role tách quyền — KHÔNG dùng superuser cho app)
#   DATABASE_URL        → mediaos_app QUA PgBouncer (:6432). MỌI query nghiệp vụ (RLS ép ở đây).
#   DATABASE_DIRECT_URL → superuser/owner, direct (:5432). Migration + bootstrap role.
#   DATABASE_WORKER_URL → mediaos_worker, direct (:5432). Outbox worker (G2-4).
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgres://mediaos_app:changeme_app_only@localhost:6432/mediaos
DATABASE_DIRECT_URL=postgres://mediaos:changeme_dev_only@localhost:5432/mediaos
DATABASE_WORKER_URL=postgres://mediaos_worker:changeme_worker_only@localhost:5432/mediaos

# ─────────────────────────────────────────────────────────────
# Mật khẩu DB role — DÙNG BỞI scripts/setup-db-roles.mjs (gán qua ALTER ROLE), TÁCH khỏi migration.
# Phải KHỚP với mật khẩu trong các URL ở trên. Chạy: `pnpm db:migrate && pnpm db:setup-roles`.
# ─────────────────────────────────────────────────────────────
APP_DB_PASSWORD=changeme_app_only
WORKER_DB_PASSWORD=changeme_worker_only
PGBOUNCER_AUTH_PASSWORD=changeme_pgbauth_only
# OWNER_DB_PASSWORD=  # chỉ cần khi prod chạy migration bằng mediaos_owner

# ─────────────────────────────────────────────────────────────
# Valkey (cache / queue / presence)
# ─────────────────────────────────────────────────────────────
VALKEY_PORT=6379
VALKEY_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────
# MinIO / S3 (object storage — artifact nhỏ; video lưu link, xem infra-zero-cost-plan §4)
# ─────────────────────────────────────────────────────────────
MINIO_ROOT_USER=mediaos
MINIO_ROOT_PASSWORD=changeme_dev_only
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=mediaos
S3_SECRET_KEY=changeme_dev_only
S3_BUCKET=mediaos-assets
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# ─────────────────────────────────────────────────────────────
# API (NestJS)
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3100
API_PREFIX=api
API_VERSION=v1
CORS_ORIGIN=http://localhost:5273

# ─────────────────────────────────────────────────────────────
# KMS / Envelope encryption (G6-2) — platform_accounts secrets, reset-token
# ─────────────────────────────────────────────────────────────
# 'local' = DEV: KEK 32 byte đọc từ file .secrets/ (ADR-0004 cấm KEK-in-env-host cho prod).
# 'vault' = PROD: HashiCorp Vault transit (cần KMS_VAULT_ADDR + KMS_VAULT_TOKEN).
KMS_PROVIDER=local
# Tạo KEK dev: node -e "require('fs').writeFileSync('.secrets/local-kek.bin',require('crypto').randomBytes(32))"
# Đặt đường dẫn TUYỆT ĐỐI (process cwd = apps/api khi chạy). KHÔNG commit file KEK (.secrets/ đã gitignore).
KMS_LOCAL_KEK_PATH=/abs/path/to/MediaOS/.secrets/local-kek.bin
# Chỉ cần khi KMS_PROVIDER=vault:
# KMS_VAULT_ADDR=http://localhost:8200
# KMS_VAULT_TOKEN=changeme_dev_only

# ─────────────────────────────────────────────────────────────
# Web (Vite) — chỉ biến VITE_* lộ ra client. KHÔNG đặt secret ở đây.
# ─────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3100/api/v1

# ─────────────────────────────────────────────────────────────
# Backup offsite (G1-8) — điền khi vận hành thật
# ─────────────────────────────────────────────────────────────
BACKUP_DIR=./backups
BACKUP_GPG_RECIPIENT=
BACKUP_B2_REMOTE=b2:mediaos-backup
BACKUP_RETENTION_DAILY=7
