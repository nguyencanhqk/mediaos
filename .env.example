# MediaOS — biến môi trường MẪU. Copy: `cp .env.example .env` rồi điền giá trị thật.
# `.env` đã gitignore. KHÔNG bao giờ commit secret thật (BẤT BIẾN #3).

# ─────────────────────────────────────────────────────────────
# Postgres (docker-compose)
# ─────────────────────────────────────────────────────────────
POSTGRES_USER=mediaos
POSTGRES_PASSWORD=changeme_dev_only
POSTGRES_DB=mediaos
POSTGRES_PORT=5432
PGBOUNCER_PORT=6432

# ─────────────────────────────────────────────────────────────
# Kết nối ứng dụng (G2-1: 3 role tách quyền — KHÔNG dùng superuser cho app)
#   DATABASE_URL        → mediaos_app QUA PgBouncer (:6432). MỌI query nghiệp vụ (RLS ép ở đây).
#   DATABASE_DIRECT_URL → superuser/owner, direct (:5432). Migration + bootstrap role.
#   DATABASE_WORKER_URL → mediaos_worker, direct (:5432). Outbox worker (G2-4).
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgres://mediaos_app:changeme_app_only@localhost:6432/mediaos
DATABASE_DIRECT_URL=postgres://mediaos:changeme_dev_only@localhost:5432/mediaos
DATABASE_WORKER_URL=postgres://mediaos_worker:changeme_worker_only@localhost:5432/mediaos

# ─────────────────────────────────────────────────────────────
# Mật khẩu DB role — DÙNG BỞI scripts/setup-db-roles.mjs (gán qua ALTER ROLE), TÁCH khỏi migration.
# Phải KHỚP với mật khẩu trong các URL ở trên. Chạy: `pnpm db:migrate && pnpm db:setup-roles`.
# ─────────────────────────────────────────────────────────────
APP_DB_PASSWORD=changeme_app_only
WORKER_DB_PASSWORD=changeme_worker_only
PGBOUNCER_AUTH_PASSWORD=changeme_pgbauth_only
# OWNER_DB_PASSWORD=  # chỉ cần khi prod chạy migration bằng mediaos_owner

# ─────────────────────────────────────────────────────────────
# Valkey (cache / queue / presence)
# ─────────────────────────────────────────────────────────────
VALKEY_PORT=6379
VALKEY_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────
# MinIO / S3 (object storage — artifact nhỏ; video lưu link, xem infra-zero-cost-plan §4)
# ─────────────────────────────────────────────────────────────
MINIO_ROOT_USER=mediaos
MINIO_ROOT_PASSWORD=changeme_dev_only
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=mediaos
S3_SECRET_KEY=changeme_dev_only
S3_BUCKET=mediaos-assets
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# ─────────────────────────────────────────────────────────────
# API (NestJS)
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3100
API_PREFIX=api
API_VERSION=v1
# CORS allowlist (origin tường minh, phẩy — KHÔNG '*' vì credentials:true). FS-1b SSO dev = subdomain
# *.localhost (web./auth.) để cookie Domain=localhost chạy giống prod. Giữ localhost:5273 cho dev non-SSO cũ.
# FS-2/3/4 (Wave 2): thêm 3 product app studio.(5276)/people.(5277)/console.(5278).
CORS_ORIGIN=http://localhost:5273,http://web.localhost:5273,http://auth.localhost:5275,http://studio.localhost:5276,http://people.localhost:5277,http://console.localhost:5278

# ─────────────────────────────────────────────────────────────
# Background worker scheduler (WAVE 4 OPS) — gọi processBatch() định kỳ
# ─────────────────────────────────────────────────────────────
# OutboxWorker + DbExportWorker là one-shot processBatch(); WorkerSchedulerService đăng ký 2 interval ĐỘC
# LẬP gọi định kỳ. Kill-switch dưới đây + TỰ TẮT khi NODE_ENV=test (spec gọi processBatch trực tiếp).
# Đa-instance an toàn: mọi instance tick nhưng worker claim bằng FOR UPDATE SKIP LOCKED (không double-process).
WORKERS_SCHEDULER_ENABLED=true
# Chu kỳ poll (ms) — số nguyên dương. outbox dày hơn (độ trễ giao event), export thưa hơn.
OUTBOX_POLL_MS=5000
EXPORT_POLL_MS=10000

# ─────────────────────────────────────────────────────────────
# SSO cookie session (FS-1) — refresh + CSRF cookie subdomain + open-redirect allowlist
# ─────────────────────────────────────────────────────────────
# AUTH_COOKIE_DOMAIN: domain cho refresh/CSRF cookie. Dev *.localhost = 'localhost' (cookie gửi cho MỌI
# *.localhost: web./auth./api.). Prod = '.<domain>' (vd '.mediaos.example'). Rỗng = host-only (KHÔNG share subdomain).
AUTH_COOKIE_DOMAIN=localhost
# AUTH_COOKIE_SECURE: cờ Secure. Dev http *.localhost = 'false'. Prod BẮT BUỘC 'true' (cần TLS wildcard *.<domain>).
AUTH_COOKIE_SECURE=false
# AUTH_REDIRECT_ALLOWLIST: origin (phẩy) được phép cho `?redirect` sau đăng nhập (chống open-redirect, rủi ro #11).
# Rỗng = deny-all (fail-closed). FS-2/3/4 (Wave 2) đã thêm studio./people./console. Prod = origin https thật.
AUTH_REDIRECT_ALLOWLIST=http://web.localhost:5273,http://studio.localhost:5276,http://people.localhost:5277,http://console.localhost:5278

# ─────────────────────────────────────────────────────────────
# KMS / Envelope encryption (G6-2) — platform_accounts secrets, reset-token
# ─────────────────────────────────────────────────────────────
# 'local' = DEV: KEK 32 byte đọc từ file .secrets/ (ADR-0004 cấm KEK-in-env-host cho prod).
# 'vault' = PROD: HashiCorp Vault transit (cần KMS_VAULT_ADDR + KMS_VAULT_TOKEN).
KMS_PROVIDER=local
# Tạo KEK dev: node -e "require('fs').writeFileSync('.secrets/local-kek.bin',require('crypto').randomBytes(32))"
# Đặt đường dẫn TUYỆT ĐỐI (process cwd = apps/api khi chạy). KHÔNG commit file KEK (.secrets/ đã gitignore).
KMS_LOCAL_KEK_PATH=/abs/path/to/MediaOS/.secrets/local-kek.bin
# Chỉ cần khi KMS_PROVIDER=vault:
# KMS_VAULT_ADDR=http://localhost:8200
# KMS_VAULT_TOKEN=changeme_dev_only
# ⚠️ Rotation worker fail-closed: SecretRotationService CHẶN chạy bằng role BYPASS RLS (super/bypassrls) vì
# role đó ghi đè được secret_ciphertext (bỏ qua column-grant). Chỉ đặt ='true' cho harness test seed/teardown
# bằng superuser — TUYỆT ĐỐI KHÔNG ở staging/prod. Mặc định (unset) = chặn. Chỉ chuỗi đúng 'true' mới nới.
# (Để value = false ở đây để bulk-uncomment .env.example vẫn fail-closed; bật bằng tay khi cần.)
ALLOW_SUPERUSER_ROTATION=false

# ─────────────────────────────────────────────────────────────
# Platform operator bootstrap — tài khoản god-mode (platform-admin chéo tenant) cấu hình qua env
# ─────────────────────────────────────────────────────────────
# Đặt PLATFORM_OPERATOR_EMAIL (+PASSWORD) → khi API khởi động, OperatorBootstrapService tự UPSERT user này
# + gán role hệ thống `platform-admin` (…f0) trong công ty PLATFORM_OPERATOR_COMPANY_SLUG. Login user này
# phát aud='operator' (control plane chéo tenant). KHÔNG đụng engine phân quyền — chỉ seed DATA (idempotent).
# ⚠️ Đây là tài khoản QUYỀN CAO NHẤT: chỉ đặt ở môi trường tin cậy, mật khẩu mạnh (≥12 ký tự), KHÔNG commit.
# Đổi email → boot lại trỏ tài khoản MỚI; operator cũ KHÔNG bị tự thu hồi (gỡ qua RBAC nếu muốn).
# Công ty (slug) PHẢI tồn tại & active TRƯỚC khi seed — seeder KHÔNG tạo công ty (nếu thiếu → log + bỏ qua).
# 2FA: role …f0 có requires_two_factor=true → với TWO_FACTOR_ENFORCEMENT_ENABLED=true (mặc định prod),
#      operator phải enroll TOTP ở lần đăng nhập đầu. Local demo: đặt TWO_FACTOR_ENFORCEMENT_ENABLED=false.
# VẮNG (mặc định) → no-op, không tạo gì.
# PLATFORM_OPERATOR_EMAIL=operator@demo.local
# PLATFORM_OPERATOR_PASSWORD=ChangeMe_Operator@12345
# PLATFORM_OPERATOR_NAME=Platform Operator
# PLATFORM_OPERATOR_COMPANY_SLUG=demo

# ─────────────────────────────────────────────────────────────
# Super-admin SẢN PHẨM bootstrap — tài khoản FULL mọi quyền TRONG 1 công ty (aud='tenant') cấu hình qua env
# ─────────────────────────────────────────────────────────────
# KHÁC operator ở trên: operator = control-plane chéo tenant (CHỈ app admin); super-admin = NGƯỜI DÙNG
# THƯỜNG đăng nhập app sản phẩm (web/studio/people) làm được MỌI nghiệp vụ trong công ty (nhân sự, lương,
# KPI, tài chính…). Đặt PLATFORM_SUPERADMIN_EMAIL (+PASSWORD) → khi API khởi động, SuperAdminBootstrapService
# UPSERT user + tạo/đồng bộ role `super-admin` (company-scoped) + grant TẤT CẢ quyền catalog + gán role.
# Idempotent + tự phủ quyền module mới mỗi boot. KHÔNG cần migration (role company-scoped, RLS cho ghi runtime).
# ⚠️ Tài khoản QUYỀN CAO NHẤT trong công ty: chỉ đặt ở môi trường tin cậy, mật khẩu mạnh (≥12 ký tự), KHÔNG commit.
# Công ty (slug) PHẢI tồn tại & active TRƯỚC khi seed — seeder KHÔNG tạo công ty (nếu thiếu → log + bỏ qua).
# TRẦN: reveal-secret mật khẩu kênh vẫn CHỈ qua break-glass per-object (ADR-0010), KHÔNG role nào với tới (cố ý).
# VẮNG (mặc định) → no-op, không tạo gì.
# PLATFORM_SUPERADMIN_EMAIL=superadmin@demo.local
# PLATFORM_SUPERADMIN_PASSWORD=ChangeMe_SuperAdmin@12345
# PLATFORM_SUPERADMIN_NAME=Super Admin
# PLATFORM_SUPERADMIN_COMPANY_SLUG=demo

# ─────────────────────────────────────────────────────────────
# Web (Vite) — chỉ biến VITE_* lộ ra client. KHÔNG đặt secret ở đây.
# ─────────────────────────────────────────────────────────────
# FS-1b SSO dev: trỏ API qua `api.localhost` để cookie `Domain=localhost` (refresh/CSRF) tự đính kèm trên
# fetch credentials:'include' (localhost host cũng nhận, nhưng *.localhost mới giống prod). Dev non-SSO cũ:
# đặt lại http://localhost:3100/api/v1 + AUTH_COOKIE_DOMAIN rỗng.
VITE_API_URL=http://api.localhost:3100/api/v1
# VITE_AUTH_APP_URL: app đăng nhập trung tâm (apps/auth). web-core điều hướng tới đây khi phiên hỏng (silent-
# refresh fail / refresh-on-401 fail) kèm `?redirect=<đích>`. Dev = auth.localhost:5275.
VITE_AUTH_APP_URL=http://auth.localhost:5275
# VITE_DEFAULT_APP_URL: landing mặc định của apps/auth sau đăng nhập khi `?redirect` vắng/không hợp lệ. Dev = web.localhost:5273.
VITE_DEFAULT_APP_URL=http://web.localhost:5273
# FS-5 launcher (apps/web): URL TUYỆT ĐỐI tới 3 product app cho các tile launcher (link cross-origin). Dev =
# subdomain *.localhost:<port> khớp vite.config từng app. Build từng app phải nhúng đúng các biến này.
VITE_STUDIO_URL=http://studio.localhost:5276
VITE_PEOPLE_URL=http://people.localhost:5277
VITE_CONSOLE_URL=http://console.localhost:5278

# ─────────────────────────────────────────────────────────────
# Backup offsite (G1-8) — điền khi vận hành thật
# ─────────────────────────────────────────────────────────────
BACKUP_DIR=./backups
BACKUP_GPG_RECIPIENT=
BACKUP_B2_REMOTE=b2:mediaos-backup
BACKUP_RETENTION_DAILY=7

# ═════════════════════════════════════════════════════════════
# FS-5 CUTOVER — TEMPLATE PROD (multi-subdomain SSO). Domain placeholder = `mediaos.example`.
# Thay `mediaos.example` bằng domain thật + đặt các biến này TRONG MÔI TRƯỜNG PROD (KHÔNG commit).
# Runbook đầy đủ (DNS · TLS wildcard · reverse proxy · CI per-app · checklist): docs/ops/fs5-cutover-runbook.md
# Mỗi VITE_* phải nhúng lúc BUILD app tương ứng (build-time, không runtime). API đọc CORS/COOKIE lúc khởi động.
# ═════════════════════════════════════════════════════════════
# --- API (apps/api @ api.mediaos.example) ---
# NODE_ENV=production
# AUTH_COOKIE_DOMAIN=.mediaos.example        # cookie refresh/CSRF share mọi subdomain (đầu '.' bắt buộc)
# AUTH_COOKIE_SECURE=true                     # BẮT BUỘC prod — cần TLS wildcard *.mediaos.example
# CORS_ORIGIN=https://mediaos.example,https://studio.mediaos.example,https://people.mediaos.example,https://console.mediaos.example,https://auth.mediaos.example
# AUTH_REDIRECT_ALLOWLIST=https://mediaos.example,https://studio.mediaos.example,https://people.mediaos.example,https://console.mediaos.example
# KMS_PROVIDER=vault                          # prod KHÔNG dùng KEK-in-file (ADR-0004)
# KMS_VAULT_ADDR=https://vault.mediaos.example
# KMS_VAULT_TOKEN=<từ secret manager, KHÔNG commit>
# --- apps/web (LAUNCHER @ mediaos.example, root domain) ---
# VITE_API_URL=https://api.mediaos.example/api/v1
# VITE_AUTH_APP_URL=https://auth.mediaos.example
# VITE_STUDIO_URL=https://studio.mediaos.example
# VITE_PEOPLE_URL=https://people.mediaos.example
# VITE_CONSOLE_URL=https://console.mediaos.example
# --- apps/auth (@ auth.mediaos.example) ---
# VITE_API_URL=https://api.mediaos.example/api/v1
# VITE_DEFAULT_APP_URL=https://mediaos.example   # bounce về launcher khi `?redirect` vắng/không hợp lệ
# --- apps/{studio,people,console} (mỗi app @ subdomain riêng) ---
# VITE_API_URL=https://api.mediaos.example/api/v1
# VITE_AUTH_APP_URL=https://auth.mediaos.example
