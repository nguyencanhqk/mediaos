{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/guard-secrets.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/guard-immutability.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/guard-tenant.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/anti-bandaid-guard.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/guard-migration-band.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/guard-scope.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/guard-claim.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/format-on-write.mjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/typecheck-on-stop.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/stop-gate.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/guard-claim.mjs"
          }
        ]
      }
    ]
  }
}
